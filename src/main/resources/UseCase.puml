@startuml
left to right direction

actor Customer
actor Admin

rectangle "Kino System" {

  usecase "View homepage" as UC1
  usecase "Browse dates" as UC2
  usecase "View showings" as UC3
  usecase "Make reservation" as UC4

  usecase "Select showing" as UC5
  usecase "Choose seats" as UC6
  usecase "Enter customer info" as UC7
  usecase "Confirm reservation" as UC8
  usecase "Return to homepage" as UC9

  usecase "Manage movies" as UC10
  usecase "Manage theatres" as UC11
  usecase "Manage showings" as UC12
  usecase "View reservations" as UC13
}

Customer --> UC1
Customer --> UC2
Customer --> UC3
Customer --> UC4

UC4 .> UC5 : <<include>>
UC4 .> UC6 : <<include>>
UC4 .> UC7 : <<include>>
UC4 .> UC8 : <<include>>
UC4 .> UC9 : <<include>>

Admin --> UC10
Admin --> UC11
Admin --> UC12
Admin --> UC13

@enduml